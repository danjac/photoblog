DEBUG=true
SECRET_KEY=django-insecure-change-me-in-development
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/postgres
REDIS_URL=redis://127.0.0.1:6379/0
EMAIL_URL=smtp://localhost:1025
ALLOWED_HOSTS=localhost,127.0.0.1
USE_HTTPS=false
USE_X_FORWARDED_HOST=false
USE_CONNECTION_POOL=false
USE_COLLECTSTATIC=false
ADMIN_URL=admin/

USE_BROWSER_RELOAD=true
USE_DEBUG_TOOLBAR=true
USE_WATCHFILES=true

# ── Deployment ────────────────────────────────────────────────────────────────
# Add these before running /dj-launch. Values are read from the environment
# (.env is gitignored — safe to add real values here. Do not add real values to .env.example).
#
# Required
# HETZNER_TOKEN=                  # Hetzner Cloud API token (Read & Write)
# CLOUDFLARE_TOKEN=               # Cloudflare API token (Zone permissions)
#
# Required for email
# MAILGUN_API_KEY=                # Mailgun sending API key
#
# Optional
# MAILGUN_DKIM_VALUE=             # Mailgun DKIM TXT record value (for DNS setup)
# HETZNER_STORAGE_ACCESS_KEY=     # Hetzner object storage access key
# HETZNER_STORAGE_SECRET_KEY=     # Hetzner object storage secret key
# SENTRY_DSN=                     # Sentry DSN URL
# OTLP_ENDPOINT=                  # OpenTelemetry collector endpoint URL
# GRAFANA_ADMIN_PASSWORD=         # Grafana admin password (auto-generated if unset)
