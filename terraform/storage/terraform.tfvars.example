# Hetzner Object Storage S3 credentials
# Create these in the Hetzner Cloud Console:
#   Cloud Console → <project> → Security → S3 credentials → Generate credentials
access_key = ""
secret_key = ""

# Object storage bucket name (must be globally unique within the region)
bucket_name = "photoblog-media"

# Hetzner datacenter location - must match where your cluster is deployed
# Options: fsn1 (Falkenstein), nbg1 (Nuremberg), hel1 (Helsinki), ash (Ashburn), hil (Hillsboro)
# After apply, your endpoint_url output will be: https://<location>.your-objectstorage.com
# e.g. with fsn1 → https://fsn1.your-objectstorage.com
#      with hel1 → https://hel1.your-objectstorage.com
# Set this as HETZNER_STORAGE_ENDPOINT in your production environment / helm values.
location = "fsn1"
